162 20 lineto
stroke
20 140 20 144 .25 2 4 arrow fill
158 20 162 20 .25 2 4 arrow fill

TI
11 139 moveto
(y) show
157 10 moveto
(x) show
TR
-18 139 moveto
(b\)) show

1.1 setlinewidth
30 23 translate
/x 0 def
/y 98 def
110 {pcurve2} repeat
80 68 1.5 0 360 arc fill
gsave
[2 2] 0 setdash
.25 setlinewidth
80 68 moveto
80 -3 lineto
stroke
grestore

220 -25 translate

.25 setlinewidth
20 0 moveto
20 144 lineto
stroke
0 20 moveto
162 20 lineto
stroke
20 140 20 144 .25 2 4 arrow fill
158 20 162 20 .25 2 4 arrow fill

TI
11 139 moveto
(y) show
157 10 moveto
(x) show
TR
-18 139 moveto
(c\)) show

/pcurve3
{x y moveto
/nx x 1 add def
/a 115 nx sub 20 div def
/ny 100 2 a exp 2 mul sub def
nx ny lineto
stroke
/x nx def
/y ny def
} def


1.1 setlinewidth
gsave
30 35 translate
/x 0 def
/y 100 2 115 20 div exp 2 mul sub def
115 {pcurve3} repeat
55 84 1.5 0 360 arc fill
gsave
[2 2] 0 setdash
.25 setlinewidth
55 84 moveto
55 -15 lineto
stroke
grestore
grestore





showpage

