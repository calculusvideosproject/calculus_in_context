  0.33333 -0.008 moveto
  0.33333 0 lineto
  stroke
  0.5 -0.008 moveto
  0.5 0 lineto
  stroke
  0.66667 -0.008 moveto
  0.66667 0 lineto
  stroke
  0.83333 -0.008 moveto
  0.83333 0 lineto
  stroke
  1 -0.008 moveto
  1 0 lineto
  stroke
 grestore
