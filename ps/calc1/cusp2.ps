%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792

25 20 translate			% print translation

/Xtrans1 50 def
/Xtrans2 170 def
/Xtrans3 290 def
/Ytrans1  50 def
/Ytrans2 20 def
/Ytrans3 30 def

/Hscale 150 def
/Vscale 150 def
/Times-Roman findfont
/fac 9 def
fac scalefont setfont

-70 -160 translate

/Mdot {
gsave
1 Hscale div 1 Vscale div scale
Vscale mul
exch
Hscale mul
exch
1.5 0 360 arc
fill
grestore} def
/Mshowa {
gsave
1 Hscale div 1 Vscale div scale   %first seven lines convert to absolute scale
4 2 roll
Vscale mul
exch
Hscale mul
exch
4 2 roll
.65 mul
exch dup .3 mul fac mul
exch 1 sub .5 mul
6 -1 roll
0 get
dup stringwidth pop
exch
7 1 roll
mul add
4 -1 roll
add
3 1 roll
.35 sub fac mul add
moveto
show
grestore
} def

