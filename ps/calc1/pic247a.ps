%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale .75 def
/recip {1 printscale div} def

printscale printscale scale

%100 300 translate			% print translation
80 0 translate

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def


/pcurve1
{x y moveto
/nx x 1 add def
/a nx 72 div def
/ny a 3 exp a sub 120 mul def
nx ny lineto
stroke
/x nx def
/y ny def
} def

/ncurve1
{x y moveto
/nx x 1 sub def
/a nx 72 div def
/ny a 3 exp a sub 120 mul def
nx ny lineto
stroke
/x nx def
/y ny def
} def

/pcurve2
{x y moveto
/nx x 1 add def
/ny nx 72 div 2 exp .3333 exp 50 mul neg def
nx ny lineto
stroke
/x nx def
/y ny def
} def

/ncurve2
{x y moveto
/nx x 1 sub def
/ny nx 72 div 2 exp .3333 exp 50 mul neg def
nx ny lineto
stroke
/x nx def
/y ny def
} def

/arrowdict 14 dict def
arrowdict begin
 /mtrx matrix def
end

/arrow
 {arrowdict begin
   /headlength exch def
   /halfheadthickness exch 2 div def
   /halfthickness exch 2 div def
   /tipy exch def /tipx exch def
   /taily exch def /tailx exch def
   
   /dx tipx tailx sub def
   /dy tipy taily sub def
   /arrowlength dx dx mul dy dy mul add sqrt def
   /angle dy dx atan def
   /base arrowlength headlength sub def
   
   /savematrix mtrx currentmatrix def
   
   tailx taily translate
   angle rotate
   0 halfthickness neg moveto
   base halfthickness neg lineto
   base halfheadthickness neg lineto
   arrowlength 0 lineto
   base halfheadthickness lineto
   base halfthickness lineto
   0 halfthickness lineto
   closepath
   
   savematrix setmatrix
   end
 }  def



.25 setlinewidth
81 0 moveto
81 144 lineto
stroke
0 20 moveto
162 20 lineto
stroke
81 140 81 144 .25 2 4 arrow fill
158 20 162 20 .25 2 4 arrow fill

TI (y) 73 140 placeBL
(x) 157 24 placeTL
(y = f) 110 105 placeBL
1 0 rmoveto
TR (\() show
TI (x) show
TR (\)) show


1.3 setlinewidth
gsave
81 60 translate
/x 0 def
/y 0 def
81 {pcurve1} repeat
/x 0 def
/y 0 def
81 {ncurve1} repeat
grestore

220 0 translate
.25 setlinewidth
81 0 moveto
81 144 lineto
stroke
0 20 moveto
162 20 lineto
stroke
81 140 81 144 .25 2 4 arrow fill
158 20 162 20 .25 2 4 arrow fill

TI (y) 73 140 placeBL
(x) 157 24 placeTL
(a) 117 10 placeBC
(y = g) 20 105 placeBL
TR (\() show
TI (x) show
TR (\)) show

gsave
[2 2] 0 setdash
.25 setlinewidth
117 20 moveto
117 130 lineto
stroke
grestore


1.3 setlinewidth
117 130 translate
/x 0 def
/y 0 def
45 {pcurve2} repeat
/x 0 def
/y 0 def
117 {ncurve2} repeat




showpage

