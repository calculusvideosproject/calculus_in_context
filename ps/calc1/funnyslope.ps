%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792

% 100 400 translate 			% print translation

/Sscale 350 def
/Vscale 150 def
/Times-Italic findfont
/fac 10 def
fac scalefont setfont

/Mdot {
gsave
1 Sscale div 1 Vscale div scale
Vscale mul
exch
Sscale mul
exch
1.5 0 360 arc
fill
grestore} def
/Mshowa {
gsave
1 Sscale div 1 Vscale div scale
4 2 roll
Vscale mul
exch
Sscale mul
exch
4 2 roll
dup 2 div abs
exch
.6 mul .4 add
3 -1 roll
dup 2 div abs
exch
4 1 roll
add
3 1 roll
add
5 -1 roll
0 get
dup stringwidth pop
6 2 roll
3 1 roll
fac mul sub
4 1 roll
3 -1 roll
mul sub
exch
moveto
show
grestore
} def


0 5 translate
Sscale Vscale scale

0.001 setlinewidth
0 0.45022 moveto
1 0.45022 lineto
stroke

