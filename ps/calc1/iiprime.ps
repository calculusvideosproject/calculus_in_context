%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792

%0 0 translate			% print translation

/Xtrans 60 def
/Ytrans1 0 def
/Ytrans2 .8 def
/Xscale 350 def
/Yscale 190 def

/Times-Roman findfont
10 scalefont setfont

-30 -20 translate

1 Xscale mul Xtrans add 20 sub .01472 Ytrans2 add Yscale mul Ytrans1 add 12 sub moveto
(days) show
1 Xscale mul Xtrans add 20 sub .17341 Yscale mul Ytrans1 add 12 sub moveto
(days) show
gsave
90 rotate
47 -50 moveto
(persons per day) show
180 -50 moveto
(infected persons) show
grestore

 
/Times-Italic findfont
10 scalefont setfont
Xtrans -1 add .63 Yscale mul moveto
(I©) show
Xtrans 0 add .63 Ytrans2 add Yscale mul moveto
(I) show
1 Xscale mul Xtrans add .012 Ytrans2 add Yscale mul Ytrans1 add 8 add moveto
(t) show
1 Xscale mul Xtrans add .172 Yscale mul Ytrans1 add 8 add moveto
(t) show
 
/arrowdict 14 dict def
arrowdict begin
 /mtrx matrix def
end

/arrow
 {arrowdict begin
   /headlength exch def
   /halfheadthickness exch 2 div def
   /halfthickness exch 2 div def
   /tipy exch def /tipx exch def
   /taily exch def /tailx exch def
   
   /dx tipx tailx sub def
   /dy tipy taily sub def
   /arrowlength dx dx mul dy dy mul add sqrt def
   /angle dy dx atan def
   /base arrowlength headlength sub def
   
   /savematrix mtrx currentmatrix def
   
   tailx taily translate
   angle rotate
   0 halfthickness neg moveto
   base halfthickness neg lineto
   base halfheadthickness neg lineto
   arrowlength 0 lineto
   base halfheadthickness lineto
   base halfthickness lineto
   0 halfthickness lineto
   closepath
   
   savematrix setmatrix
   end
 }  def
 

Xtrans Ytrans1 translate
Xscale Yscale scale

0.001 setlinewidth
0 0.17341 moveto
1 0.17341 lineto
stroke
0.02262 0 moveto
0.02262 0.61803 lineto
stroke
gsave

newpath
.02262 .61803 .02262 .64203 .0002 .005 .02 arrow
fill
newpath 
1 .17341 1.016 .17341 .002 .008 .012 arrow
fill


[.01 .01] 0 setdash
0.17124 0.17197 moveto
0.17124 .60332 Ytrans2 add lineto
stroke
0.10019 0.60332 moveto
0.10019 .354 Ytrans2 add lineto
stroke
0.2446 0.01472 moveto
0.2446 0.48449 Ytrans2 add lineto
stroke
grestore

