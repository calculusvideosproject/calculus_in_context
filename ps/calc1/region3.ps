%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale .8 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

%100 300 translate		% print translation

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def



% ----- program ------

.3 setlinewidth


% ------------------ first figure ----------------------

% set the origin
% 50 100 moveto
 50 -137 moveto
currentpoint translate


gsave  % start clipped region for graph

newpath
0 0 moveto 
0 150 rlineto
125 0 rlineto
0 -150 rlineto
-125 0 rlineto
clip

newpath
.8 recip setlinewidth
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke

grestore % end clipped region for graph

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% --------------------------------------------------------------


% coordinate axes
newpath
-40 0 moveto
190 0 rarrowto
-20 -10 moveto
0 130 rarrowto
fill

newpath
0 0 moveto
0 41.5 rlineto
125 0 moveto
0 120 rlineto
stroke


% rectangle
newpath
75 0 moveto
0 122 rlineto
15 0 rlineto
0 -122 rlineto
stroke
%thick top
gsave
.3 recip mul setlinewidth
75 122 moveto
15 0 rlineto
stroke
grestore

newpath
.3 recip mul setlinewidth
65 28 moveto
9 0 rarrowto
100 28 moveto
-9 0 rarrowto
97 64.8 moveto
-14 0 rarrowto
fill

gsave 					% save solid lines
newpath
[1 1] 1 setdash
82 0 moveto
0 122 rlineto
stroke
grestore					% restore solid lines

% labels on axes and rectangle
newpath
TI (a) 0 0 placeTC
(b) 125 0 placeTC 
(x) 150 0 placeTC
(y) -23 118 placeBR
(f) 99 62 placeBL
1 0 rmoveto TR (\() show
TI (x) show
0 -2 rmoveto ti (k) show
0 2 rmoveto TR (\)) show
TI (x) 82 0 placeTC
0 -2 rmoveto ti (k) show
47 25 moveto SYM (D) show
TI (x) show
0 -2 rmoveto ti (k) show



% --------------- second figure --------------------

% set the origin
232 0 moveto
currentpoint translate

gsave  % start clipped region for graph

newpath
0 0 moveto 
0 150 rlineto
125 0 rlineto
0 -150 rlineto
-125 0 rlineto
clip

newpath
.8 recip setlinewidth
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke

grestore % end clipped region for graph


% coordinate axes
newpath
-40 0 moveto
190 0 rarrowto
-20 -10 moveto
0 130 rarrowto
fill

newpath
0 0 moveto
0 41.5 rlineto
125 0 moveto
0 120 rlineto
stroke


% rectangles
newpath
0 0 moveto
0 41 rlineto
40 0 rlineto
40 0 moveto
0 51 rlineto
15 0 rlineto
55 0 moveto
0 76 rlineto
10 0 rlineto
65 0 moveto
0 104 rlineto
10 0 rlineto
75 0 moveto
0 122 rlineto
15 0 rlineto
90 0 moveto
0 127.5 rlineto
20 0 rlineto
0 -127.5 rlineto
110 123 moveto
15 0 rlineto
0 -123 rlineto
stroke
% thick tops - but not thickened!
gsave
newpath
.3 recip mul setlinewidth
0 41 moveto
40 0 rlineto
40 51 moveto
15 0 rlineto
55 76 moveto
10 0 rlineto
65 104 moveto
10 0 rlineto
75 122 moveto
15 0 rlineto
90 127.5 moveto
20 0 rlineto
110 123 moveto
15 0 rlineto
stroke
grestore

% labels on axes
newpath
TI (a) 0 0 placeTC
(b) 125 0 placeTC 
(x) 150 0 placeTC
(y) -23 118 placeBR


showpage


