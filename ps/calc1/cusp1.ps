[(\(0, 0\))] .02381 .01472 1 0 Mshowa
[(\(2, 1.58740\))] .97619 .60332 -1 .5 Mshowa
0.004 setlinewidth


gsave     %draws lines to next box
[.005 .005] 0 setdash
0.0005 setlinewidth
0.54762 0.40984 moveto
0.97619 Xtrans2 Xtrans1 sub Hscale div add 0.60332 Ytrans2 Ytrans1 sub Vscale div add lineto
stroke
0.45238 0.36036 moveto
0.02381  Xtrans2 Xtrans1 sub Hscale div add 0.01472 Ytrans2 Ytrans1 sub Vscale div add lineto
stroke
grestore

/rangle 
{0.40984 0.60332 Ytrans2 Ytrans1 sub Vscale div add exch sub Vscale mul
0.54762 0.97619 Xtrans2 Xtrans1 sub Hscale div add exch sub Hscale mul
atan} def
gsave
0.54762 0.40984 translate
rangle rotate
[(10x)] .5 0 0 .8 Mshowa
grestore


grestore

