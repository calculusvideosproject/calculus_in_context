%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1 def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

%100 300 translate		% print translation

 printscale printscale scale        %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen


% ----- font codes -------

/TR8 
{/Times-Roman findfont 7 scalefont setfont} def

/typesize {10 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def


% ------------------- left side figure --------------------

.3 setlinewidth



% position the origin of orthogonal coordinate system
% -26 0 moveto					% even-side origin
22 0 moveto					% odd-side origin
currentpoint translate

gsave 						% save picture coords

[.95 -.1 0 1 0 0] concat			% make frame coordinates

/frame matrix currentmatrix def	% define frame coords



% ------ arrow drawing procedures --------

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def

% ----------------------------------------

% x-axis 
newpath
-25 -40 moveto
200 0 rlineto
rightarrow
fill
-17 -43 moveto
0 6 rlineto
stroke
100 -40 1.2 0 360 arc		% dot marking x
fill

% cross-section
newpath
100 21 translate			% coordinates for 
.3 1 scale				% elliptical cross-section
0 0 43 0 360 arc
.9 setgray
fill

frame setmatrix			% restore frame coords
0 setgray					% restore black lines



% ---------------------- object -------------------------

1 .5 scale				% compressed coords 

newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke

frame setmatrix			% restore frame coords

% -------------- text -----------------

TI (x) 175 -38 placeTC
(x) 100 -38 placeTC

100 16 translate			% move coords to 
[.3 .3 0 1 0 0] concat		% cross-section
/typesize 20 def			% enlarge type size
TR (A\() -90 0 placeBR
TI (x) show
TR (\)) show
/typesize 
{10 printscale div} def		% restore original type size


newpath
-70 5 moveto
22 0 rlineto
rightarrow
fill

grestore					% restore picture coords


% -------------- end left side figure -------------------

% -------------- right side figure ----------------------



% position the origin of orthogonal coordinate system
220 0 moveto
currentpoint translate

gsave 						% save picture coords

[.95 -.1 0 1 0 0] concat			% make frame coordinates

/frame matrix currentmatrix def		% define frame coords




% x-axis 
newpath
-25 -40 moveto
200 0 rlineto
rightarrow
fill
-17 -43 moveto
0 6 rlineto
15 -43 moveto
0 6 rlineto
38 -43 moveto
0 6 rlineto
stroke
0 -40 1.2 0 360 arc			% dot marking x
fill
25 -40 1.2 0 360 arc			% dot marking x
fill

% vertical dotted lines
newpath
[1 2] 0 setdash
-17 -58 moveto
0 61 rlineto
0 -38 moveto
0 48 rlineto
15 -58 moveto
0 40 rlineto
25 -38 moveto
0 37 rlineto
38 -58 moveto
0 34 rlineto
stroke
[] 0 setdash

newpath
% delta x_1
-14 -53 moveto
26 0 rlineto
rightarrow
-14 -53 moveto
leftarrow

%delta x_2
17 -53 moveto
19 0 rlineto
rightarrow
17 -53 moveto
leftarrow
fill


% ------------------ cross-sections ------------------------

% solid curves
newpath
15 3 translate			% coordinates for 
.3 1 scale				% elliptical cross-section
0 0 17.5 0 360 arc
stroke
frame setmatrix			% restore frame coords

newpath
38 0 translate			% coordinates for 
.3 1 scale				% elliptical cross-section
0 0 21 0 360 arc
stroke
frame setmatrix			% restore frame coords

% shaded sections
newpath
0 6.5 translate			% coordinates for 
.3 1 scale				% elliptical cross-section
0 0 14 0 360 arc
.9 setgray
fill
frame setmatrix			% restore frame coords

newpath
25 1 translate			% coordinates for 
.3 1 scale				% elliptical cross-section
0 0 19 0 360 arc
fill
frame setmatrix			% restore frame coords
0 setgray					% restore black lines

% ---------------------- object -------------------------

1 .5 scale				% compressed coords 

newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke

frame setmatrix			% restore frame coords

% ------------ text ----------------

TI (x) 175 -38 placeTC
(x) -2 -38 placeTC
TR8 0 -2 rmoveto (1) show
TI (x) 23 -38 placeTC
TR8 0 -2 rmoveto (2) show
SYM (D) -8 -51 placeTL
TI 1 0 rmoveto (x) show
TR8 0 -2 rmoveto (1) show
SYM (D) 18 -51 placeTL
TI 1 0 rmoveto (x) show
TR8 0 -2 rmoveto (2) show




% --------------- end right side figure -----------------

grestore					% restore picture coords



% -------------------------------------------------------



showpage


