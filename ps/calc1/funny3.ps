%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792

% 100 400 translate			% print translation

/Sscale 350 def
/Vscale 150 def
/Times-Italic findfont
/fac 10 def
fac scalefont setfont

/Mdot {
gsave
1 Sscale div 1 Vscale div scale
Vscale mul
exch
Sscale mul
exch
1.5 0 360 arc
fill
grestore} def
/Mshowa {
gsave
1 Sscale div 1 Vscale div scale   %first seven lines convert to absolute scale
4 2 roll
Vscale mul
exch
Sscale mul
exch
4 2 roll
.65 mul
exch dup .3 mul fac mul
exch 1 sub .5 mul
6 -1 roll
0 get
dup stringwidth pop
exch
7 1 roll
mul add
4 -1 roll
add
3 1 roll
.35 sub fac mul add
moveto
show
grestore
} def


10 15 translate
Sscale Vscale scale

0.001 setlinewidth
0 0.15549 moveto
1 0.15549 lineto
stroke

/fix {Vscale Sscale div} def

