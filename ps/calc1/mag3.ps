MathPictureEnd%%PSTrailer
end

% Mathematica code
%
% Show[graph3, Graphics[box2], Graphics[box3]]
% graph3 =
% Plot[ funny, {x, 26.8, 27.2},
% 	AspectRatio -> .95,
% 	PlotRange -> {69.5, 70.5},
% 	AxesOrigin -> {26.8, 69.5} 
% ]
% box2 =
% Line[{{26.8, 69.5}, {26.8, 70.5}, {27.2, 70.5}, {27.2, 69.5}, {26.8, 69.5}}]
% box3 =
% Line[{{26.98, 69.82}, {26.98, 69.9}, {27.02, 69.9}, {27.02, 69.82}, {26.98, 69.82}}]
% funny = (2 + x^3 Cos[x] + 1.5^x)/(2 + x^2)
% 
%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	
/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -300 
{ 0 exch moveto
  500 0 rlineto
} for
% stroke			% comment out here to eliminate grid lines
grestore

