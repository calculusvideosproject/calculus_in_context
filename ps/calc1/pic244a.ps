%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1 def
/recip {1 printscale div} def

%100 300 translate		% print translation

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% ------------------ graphics instructions --------------------

.3 setlinewidth

% position the origin
0 0 moveto
currentpoint translate

newpath
35 10 moveto
0 110 rarrowto
20 78 moveto
340 0 rarrowto
fill


% -------------------- font codes --------------------------

/typesize {10 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% labels
TI (x) 357 70 placeBL
(y) 31 117 placeBR
(a) 89 70 placeBC
(b) 130 80 placeBC
(c) 170 70 placeBC
(d) 216 80 placeBC

/dot {1.8 printscale div 0 360 arc fill} def		% stack: x y

newpath
89.5 98 dot
129.5 72.8 dot
169.5 85.7 dot
215.2 31.7 dot

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 300 rlineto
} for
0 50 300 
{ 0 exch moveto
  500 0 rlineto
} for
% stroke			% comment out here to eliminate grid lines
grestore


/Hscale 350 def
/Vscale 150 def
/Times-Italic findfont
/fac 10 def
fac scalefont setfont

/Mdot {
gsave
1 Hscale div 1 Vscale div scale
Vscale mul
exch
Hscale mul
exch
1.5 0 360 arc
fill
grestore} def
/Mshowa {
gsave
1 Hscale div 1 Vscale div scale   %first seven lines convert to absolute scale
4 2 roll
Vscale mul
exch
Hscale mul
exch
4 2 roll
.65 mul
exch dup .3 mul fac mul
exch 1 sub .5 mul
6 -1 roll
0 get
dup stringwidth pop
exch
7 1 roll
mul add
4 -1 roll
add
3 1 roll
.35 sub fac mul add
moveto
show
grestore
} def

/arrowdict 14 dict def
arrowdict begin
 /mtrx matrix def
end

/arrow
 {arrowdict begin
   /headlength exch def
   /halfheadthickness exch 2 div def
   /halfthickness exch 2 div def
   /tipy exch def /tipx exch def
   /taily exch def /tailx exch def
   
   /dx tipx tailx sub def
   /dy tipy taily sub def
   /arrowlength dx dx mul dy dy mul add sqrt def
   /angle dy dx atan def
   /base arrowlength headlength sub def
   
   /savematrix mtrx currentmatrix def
   
   tailx taily translate
   angle rotate
   0 halfthickness neg moveto
   base halfthickness neg lineto
   base halfheadthickness neg lineto
   arrowlength 0 lineto
   base halfheadthickness lineto
   base halfthickness lineto
   0 halfthickness lineto
   closepath
   
   savematrix setmatrix
   end
 }  def



0 10 translate
Hscale Vscale scale

/fix {Vscale Hscale div} def

gsave
