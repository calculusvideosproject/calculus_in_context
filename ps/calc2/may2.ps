%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale .8 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate		% print translation

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% -------------------------- program ----------------------------

.3 setlinewidth

% position the origin
%100 500 moveto				% screen origin
20 printscale div 0 printscale div moveto
currentpoint translate

% ------------------ ticks -----------------

% ticks
/htick {0 -2 rlineto} def
/hscale {currentpoint
pop 50 add 0 moveto 
htick} def
/vtick {-2 0 rlineto} def
/vscale {currentpoint
20 add 0 exch moveto
vtick} def

% ----------------------  Euler's method ------------------------------

% -------------- differential equations -----------------
% x' = .6x(1-x/10) - .5xy/(x+1)
% y' = .1y(1-y/(2x))

/xmay
{/xp .5 x mul y mul x 1 add div x 10 div neg 1 add x mul .6 mul sub neg def
/yp  y x div 2 div neg 1 add y mul .1 mul def
/nx x xp .05 mul add def
/ny y yp .05 mul add def
/nt t .1 add def
t x 10 mul moveto
nt nx 10 mul lineto
stroke
/x nx def
/y ny def
/t nt def
} def

/ymay
{/xp .5 x mul y mul x 1 add div x 10 div neg 1 add x mul .6 mul sub neg def
/yp  y x div 2 div neg 1 add y mul .1 mul def
/nx x xp .05 mul add def
/ny y yp .05 mul add def
/nt t .1 add def
t y 10 mul moveto
nt ny 10 mul lineto
stroke
/x nx def
/y ny def
/t nt def
} def


% ------------------------ first graph ------------------------


% coord lines

0 0 moveto
420 0 arrowto
0 0 moveto
0 100 arrowto
fill
0 0 moveto
8 {hscale} repeat
0 0 moveto
4 {vscale} repeat
stroke


% plot solution

gsave
.9 recip mul setlinewidth

/x 8 def
/y 2 def
/t 0 def
 3800 {ymay} repeat

/x 8 def
/y 2 def
/t 0 def
 3800 {xmay} repeat
grestore

% labels

TI (t) 420 0 placeTC
(x, y) -4 100 placeBR
sym (8) -5 78 placeBR
(2) -5 18 placeBR
(0) 0 1 placeTC
(50) 100 1 placeTC
(100) 200 1 placeTC
(150) 300 1 placeTC
(200) 400 1 placeTC
TI (x) 385 61 placeBL
1 0 rmoveto
TR (: prey) show
TI (y) 385 14 placeBL
1 0 rmoveto
TR (: predator) show
 
% ----------------- second graph -----------------------

0 -130 moveto
currentpoint translate

% coord lines

0 0 moveto
420 0 arrowto
0 0 moveto
0 100 arrowto
fill
0 0 moveto
8 {hscale} repeat
0 0 moveto
4 {vscale} repeat
stroke

% plot solution

gsave
.9 recip mul setlinewidth

/x 1.1 def
/y 2.2 def
/t 0 def
 3800 {ymay} repeat

/x 1.1 def
/y 2.2 def
/t 0 def
 3800 {xmay} repeat
grestore
% labels

TI (t) 420 0 placeTC
(x, y) -4 100 placeBR
sym (1.1) -4 8 placeBR
(2.2) -4 22 placeBR
(0) 0 1 placeTC
(50) 100 1 placeTC
(100) 200 1 placeTC
(150) 300 1 placeTC
(200) 400 1 placeTC
TI (x) 340 71 placeBL
1 0 rmoveto
TR (: prey) show
TI (y) 365 35 placeBL
1 0 rmoveto
TR (: predator) show
 
% -------- third graph ------------

0 -150 moveto
currentpoint translate



% coord lines

0 0 moveto
420 0 arrowto
0 0 moveto
0 120 arrowto
fill
0 0 moveto
8 {hscale} repeat
0 0 moveto
5 {vscale} repeat
stroke

% plot solution

gsave
.9 recip mul setlinewidth

/x 10 def
/y .1 def
/t 0 def
 3800 {ymay} repeat

/x 10 def
/y .1 def
/t 0 def
 3800 {xmay} repeat
grestore

% labels

TI (t) 420 0 placeTC
(x, y) -4 120 placeBR
sym (10) -5 97 placeBR
(.1) -4 0 placeBR
(0) 0 1 placeTC
(50) 100 1 placeTC
(100) 200 1 placeTC
(150) 300 1 placeTC
(200) 400 1 placeTC
TI (x) 385 71 placeBL
1 0 rmoveto
TR (: prey) show
TI (y) 385 27 placeBL
1 0 rmoveto
TR (: predator) show
 


showpage

