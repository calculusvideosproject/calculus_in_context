% coord axes
newpath
0 0 moveto
350 0 rarrowto
0 0 moveto
0 125 rarrowto
fill

% ticks
/htick {0 -2 rlineto} def
/vtick {-2 0 rlineto} def
/hscale {currentpoint
pop 60 add 0 moveto 
htick} def
/vscale {currentpoint 
16 add 0 exch moveto
vtick} def

newpath
0 0 moveto
htick
5 {hscale} repeat
0 0 moveto
7 {vscale} repeat
stroke

% labels
sym 
(1820) 0 -3 placeTC
(1840) 60 -3 placeTC
(1860) 120 -3 placeTC
(1880) 180 -3 placeTC
(1900) 240 -3 placeTC
(1920) 300 -3 placeTC
(2000) -7 29 placeBR
(4000) -7 61 placeBR
(6000) -7 93 placeBR
TR (year) 350 -1 placeTC
(Annual harvest of lynx pelts) 180 -20 placeTC
gsave
90 rotate
(pelts) 70 36 placeBC
grestore

showpage
