%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale  .95 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

30 10 translate

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {7 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% --------------------------------------------------------------

.3 setlinewidth

/grid
 {0 0 moveto stepsperunit 2 mul stepsperunit 2 idiv add 20 add 0 arrowto fill
0 0 moveto 0 ht 20 add arrowto fill
.3 setlinewidth
stepsperunit -2 moveto
stepsperunit 0 lineto stroke
stepsperunit 2 mul -2 moveto
stepsperunit 2 mul 0 lineto stroke
stepsperunit 2 sub -10 moveto
sym (1) show
stepsperunit 2 mul 2 sub -10 moveto
(2) show
} def

/place
{stepsperunit 10 add ht 10 sub moveto
TR (degree ) show show
} def

/stepsperunit 50 def
/delta 1 stepsperunit div def
/ht 50 def

/poly1
{/y 1.00722 -.453645 nx mul add def
} def

/poly2
{/y 1.08789 -.69566 .121008 nx mul add nx mul add def
} def

/poly3
{/y 1.04245 -.423017 -.219797 .113602 nx mul add nx mul add nx mul add def
} def

/poly4
{/y 1.00704 -.0689061 -1.01653 .733272 -.154916 nx mul add nx mul add nx mul add nx mul add def
} def

/curve1
{/x x 1 add def
/nx x delta mul def
poly1
x y ht mul lineto
} def

/negcurve1
{/x x 1 sub def
/nx x delta mul def
poly1
x y ht mul lineto
} def

/curve2
{/x x 1 add def
/nx x delta mul def
poly2
x y ht mul lineto
} def

/negcurve2
{/x x 1 sub def
/nx x delta mul def
poly2
x y ht mul lineto
} def

/curve3
{/x x 1 add def
/nx x delta mul def
poly3
x y ht mul lineto
} def

/negcurve3
{/x x 1 sub def
/nx x delta mul def
poly3
x y ht mul lineto
} def

/curve4
{/x x 1 add def
/nx x delta mul def
poly4
x y ht mul lineto
} def

/negcurve4
{/x x 1 sub def
/nx x delta mul def
poly4
x y ht mul lineto
} def

/geom
{/x x 1 add def
/nx x delta mul def
/y 1 1 nx nx mul add div ht mul def
x y lineto
}def

/neggeom
{/x x 1 sub def
/nx x delta mul def
/y 1 1 nx nx mul add div ht mul def
x y lineto
}def

/geomdraw
{.9 recip mul setlinewidth
/x 0 def
/y ht def
x y moveto
stepsperunit 2 mul stepsperunit 2 idiv add {geom} repeat
stroke
/x 0 def
/y ht def
x y moveto
stepsperunit 2 idiv {neggeom} repeat
stroke
.6 recip mul setlinewidth
[2 1] 0 setdash
} def

gsave
stepsperunit 2 idiv ht 60 add translate
grid
geomdraw
/x 0 def
/y 1.00722 ht mul def
x y moveto
stepsperunit 2 mul stepsperunit 2 idiv add {curve1} repeat
stroke
/x 0 def
/y 1.00722 ht mul def
x y moveto
stepsperunit 2 idiv {negcurve1} repeat
stroke
(1) place
grestore

gsave
180 stepsperunit 2 idiv add 20 translate
grid
geomdraw
/x 0 def
/y 1.00704 ht mul def
x y moveto
stepsperunit 2 mul stepsperunit 2 idiv add {curve4} repeat
stroke
/x 0 def
/y 1.00704 ht mul def
x y moveto
stepsperunit 2 idiv {negcurve4} repeat
stroke
(4) place
grestore

gsave
stepsperunit 2 idiv 20 translate
grid
geomdraw
/x 0 def
/y 1.04245 ht mul def
x y moveto
stepsperunit 2 mul stepsperunit 2 idiv add {curve3} repeat
stroke
/x 0 def
/y 1.04245 ht mul def
x y moveto
stepsperunit 2 idiv {negcurve3} repeat
stroke
(3) place
grestore

gsave
180 stepsperunit 2 idiv add ht 60 add translate
grid
geomdraw
/x 0 def
/y 1.08789 ht mul def
x y moveto
stepsperunit 2 mul stepsperunit 2 idiv add {curve2} repeat
stroke
/x 0 def
/y 1.08789 ht mul def
x y moveto
stepsperunit 2 idiv {negcurve2} repeat
stroke
(2) place
grestore

showpage

