%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale .6 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% -------------------- Ken's arrow drawing procedure --------------

/arrow
 {/mtrx matrix def
   /headlength exch def
   /halfheadthickness exch 2 div def
   /halfthickness exch 2 div def
   /tipy exch def /tipx exch def
   /taily exch def /tailx exch def
   
   /dx tipx tailx sub def
   /dy tipy taily sub def
   /arrowlength dx dx mul dy dy mul add sqrt def
   dx 0 ne {/angle dy dx atan def}
   	{dy 0 ne {/angle 90 dy dy abs div mul def}{/angle 0 def} ifelse}
	 ifelse
   /base arrowlength headlength sub def
   
   /savematrix mtrx currentmatrix def
   
   tailx taily translate
   angle rotate
   0 halfthickness neg moveto
   base halfthickness neg lineto
   base halfheadthickness neg lineto
   arrowlength 0 lineto
   base halfheadthickness lineto
   base halfthickness lineto
   0 halfthickness lineto
   closepath
   
   savematrix setmatrix
 }  def
 
% -------------------------- program ----------------------------

.3 setlinewidth

 /Sc   %scales points
 {ymin sub vscale mul exch xmin sub hscale mul exch} def
 
 /Schead
 {/dx rtip x sub hscale mul def
 /dy ftip y sub vscale mul def
 /s dx dx mul dy dy mul add sqrt .1 mul def
 s mul exch s mul exch} def
 
 /model
 {/xp .1 x mul 1 x 10000 div sub mul .005 x y mul mul sub def
 /yp .00004 x y mul mul .04 y mul sub def
 /x x xp step mul add def
 /y y yp step mul add def
 /t t step add def
 x y Sc lineto
 } def
 
/model1
{/xp .15 x mul 1 .005 x mul sub .01 y mul sub mul def
 /yp .03 y mul 1 .006 x mul sub .005 y mul sub mul def
/x x xp step mul add def
/y y yp step mul add def
x y Sc lineto } def

/manyrun1
{/inity exch def
/initx exch def
/nrun exch def
/x initx def
/y inity def
x y Sc moveto
nrun {model1} repeat
stroke
/sign xp xp abs div def
/rat yp xp div def
/xtip x .2 sign mul add def
/ytip y .2 sign rat mul mul add def
x y Sc xtip ytip Sc .1 3 5 arrow fill
x y Sc moveto
totalsteps {model1} repeat
stroke
} def

/many
{20 k sub  fxmin begy manyrun1
/begy begy .2 add def
/k k 1 add def
} def

 /fntsize 10 def
  /hscale 100 def  
 /vscale .68 hscale mul def
    
 /xmax 36 def
 /xmin 34 def
 /ymax 51 def
 /ymin 49 def
 /fxmin xmin .1 sub def
/fymin ymin .1 sub def
/fxmax xmax .1 add def
/fymax ymax .1 add def
/totalsteps 100 def
/tmax 5 def
/step tmax totalsteps div def

     
220 22 translate


.3 recip mul setlinewidth 
newpath
fxmin  fymin  Sc moveto 
fxmax  fymin  Sc lineto
fxmax  fymax  Sc lineto
fxmin  fymax  Sc lineto
closepath
gsave
stroke
grestore
clip

newpath
gsave
.82 recip mul setlinewidth
/begy 47 def
/k 0 def
20 {many} repeat
grestore

newpath
gsave
35.02 49.90 Sc moveto
10 recip mul 0  rlineto
0 8 recip mul rlineto
-9 recip mul 0 rlineto
closepath
1 setgray
fill
grestore

 newpath
35 50 Sc 1.5 0 360 arc fill
TI (Q) 35.04 49.94 Sc placeBL

showpage
