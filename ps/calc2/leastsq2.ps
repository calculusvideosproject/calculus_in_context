%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale  .95 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

20 -7 translate

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {7 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% --------------------------------------------------------------

.3 setlinewidth

 
 /grid
 {stepsperunit stepsperunit 4 idiv add neg 0 moveto stepsperunit stepsperunit 4 idiv add 0 arrowto fill
0 0 moveto 0 ht 20 add arrowto fill
stepsperunit -2 moveto
stepsperunit 0 lineto stroke
stepsperunit neg -2 moveto
stepsperunit neg 0 lineto stroke
stepsperunit neg 5 sub -10 moveto
sym (-1) show
stepsperunit  2 sub -10 moveto
(1) show
} def

/place
{10 ht  moveto
TR (degree ) show show
} def

/stepsperunit 60 def
/delta 1 stepsperunit div def
/ht 60 def

/poly1
{/y .1875 .9375 nx mul add def
} def

/poly2
{/y .117188 1.64062 -.820312 nx mul add nx mul add def
} def

/poly3
{/y .0854492 2.30713 -2.81982 1.46631 nx mul add nx mul add nx mul add def
} def

/poly4
{/y .0672911 2.9608213 -6.4151315 7.6981733 -3.3384984 nx mul add nx mul add nx mul add nx mul add def
} def

/curve1
{/x x 1 add def
/nx x delta mul 2 exp def
poly1
x y ht mul lineto
} def

/negcurve1
{/x x 1 sub def
/nx x delta mul 2 exp def
poly1
x y ht mul lineto
} def

/curve2
{/x x 1 add def
/nx x delta mul 2 exp def
poly2
x y ht mul lineto
} def

/negcurve2
{/x x 1 sub def
/nx x delta mul 2 exp def
poly2
x y ht mul lineto
} def

/curve3
{/x x 1 add def
/nx x delta mul 2 exp def
poly3
x y ht mul lineto
} def

/negcurve3
{/x x 1 sub def
/nx x delta mul 2 exp def
poly3
x y ht mul lineto
} def

/curve4
{/x x 1 add def
/nx x delta mul 2 exp def
poly4
x y ht mul lineto
} def

/negcurve4
{/x x 1 sub def
/nx x delta mul 2 exp def
poly4
x y ht mul lineto
} def

/abscurve
{stepsperunit stepsperunit 4 idiv add neg ht ht 4 idiv add moveto
0 0 lineto
stepsperunit stepsperunit 4 idiv add  ht ht 4 idiv add lineto
}def

/absdraw
{.9 recip mul setlinewidth
abscurve
stroke
.6 recip mul setlinewidth
[2 1] 0 setdash
} def

gsave
stepsperunit stepsperunit 2 idiv add  ht 70 add translate
grid
absdraw
/x 0 def
/y .1875 ht mul def
x y moveto
stepsperunit stepsperunit 5 idiv add {curve1} repeat
stroke
/x 0 def
/y .1875 ht mul def
x y moveto
stepsperunit stepsperunit 5 idiv add {negcurve1} repeat
stroke
(2) place
grestore

gsave
180 stepsperunit stepsperunit 2 idiv add add 20 translate
grid
absdraw
/x 0 def
/y .0672911 ht mul def
x y moveto
stepsperunit 8 add {curve4} repeat
stroke
/x 0 def
/y .0672911 ht mul def
x y moveto
stepsperunit 8 add {negcurve4} repeat
stroke
(8) place
grestore

gsave
stepsperunit stepsperunit 2 idiv add 20 translate
grid
absdraw
/x 0 def
/y .0854492 ht mul def
x y moveto
stepsperunit 5 add {curve3} repeat
stroke
/x 0 def
/y .0854492 ht mul def
x y moveto
stepsperunit 5 add {negcurve3} repeat
stroke
(6) place
grestore

gsave
180 stepsperunit stepsperunit 2 idiv add add ht 70 add translate
grid
absdraw
/x 0 def
/y .117188 ht mul def
x y moveto
stepsperunit stepsperunit 4 idiv add {curve2} repeat
stroke
/x 0 def
/y .117188 ht mul def
x y moveto
stepsperunit stepsperunit 4 idiv add {negcurve2} repeat
stroke
(4) place
grestore

showpage

