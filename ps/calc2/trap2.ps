%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1.2 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

10 -25 translate

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {7 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

/placeSL   %stack: fontcode string x y 
{ dup neg
4 1 roll 
exch
dup neg
5 1 roll
exch
translate
90 rotate
%dup stringwidth pop
%neg 0
0 0 moveto
show
-90 rotate
translate} def


/placeSC   %stack: fontcode string x y 
{ dup neg
4 1 roll 
exch
dup neg
5 1 roll
exch
translate
90 rotate
dup stringwidth pop
2 div
neg 0
moveto
show
-90 rotate
translate} def


/placeSR   %stack: fontcode string x y 
{ dup neg
4 1 roll 
exch
dup neg
5 1 roll
exch
translate
90 rotate
dup stringwidth pop
neg 0
moveto
show
-90 rotate
translate} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def



% ------------------------ program ------------------------------

.3 recip mul setlinewidth

% -------------------------- trapezoid ---------------------------------

% set the origin
 40 0 moveto
% 0 180 moveto
currentpoint translate

gsave		% start clipped region for shading

newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
clip


grestore	% end clipped region for shading

% trapezoid with graph

gsave				% begin medium lines
.5 recip mul setlinewidth
newpath
75 0 moveto
75 113.7 lineto
90 126.4 lineto
90 0 lineto
closepath
stroke

% rectangles - dotted lines

gsave
[1 1] 0 setdash
newpath
90 113.7 moveto
75 113.7 lineto
75 126.4 lineto
90 126.4 lineto
stroke
grestore
grestore			% end medium lines


gsave  % start clipped region for graph

newpath
-10 0 moveto 
0 150 rlineto
150 0 rlineto
0 -150 rlineto
-150 0 rlineto
clip

gsave				% begin thick lines
.9 recip mul setlinewidth
newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke
grestore			% end thick lines

grestore % end clipped region for graph

% coordinate axes
newpath
-40 0 moveto
190 0 rarrowto
-20 -10 moveto
0 130 rarrowto
fill

% central rectangle/trapezoid
newpath
0 0 moveto
0 2 rlineto
125 0 moveto
0 2 rlineto
stroke

75.1 -10 moveto
0 9 rarrowto
90.1 -10 moveto
0 9 rarrowto
fill

 
% labels on axes and graph
newpath
TI (a) 0 0 placeTC
(b) 126 0 placeTC 
(x) 150 0 placeTC
(y) -23 118 placeBR
(y = f) -5 47 placeBL
1 0 rmoveto TR (\() show
TI (x) show
TR (\)) show
(left) 75 -9 placeTR
(endpoint) 75 -16 placeTR
(right) 90 -9 placeTL
(endpoint) 90 -16 placeTL

% big arrow

newpath
118 40 moveto
20 0 rlineto
0 -5 rlineto
20 20 rlineto
-20 20 rlineto
0 -5 rlineto
-20 0 rlineto
closepath
stroke

% --------------------  two rectangles and one trapezoid ------------------

105 0 moveto
currentpoint translate

.5 recip mul setlinewidth	% begin medium lines

gsave
[1 1] 0 setdash
newpath
75 0 moveto
75 113.7 lineto
90 113.7 lineto
90 0 lineto
closepath
stroke

60 0 moveto
currentpoint translate
newpath
75 0 moveto
75 126.4 lineto
90 126.4 lineto
90 0 lineto
closepath
stroke

grestore

30 0 moveto
currentpoint translate

newpath
75 0 moveto
75 113.7 lineto
90 126.4 lineto
90 0 lineto
closepath
stroke

75 0 moveto
currentpoint translate

% labels
% TR (left) -18 126 placeBR
% (rectangle) -18 118 placeBR
% (right) 35 138 placeBL
% (rectangle) 35 130 placeBL
% (trapezoid) 

TR (left rectangle) -20 20 placeSL
(right rectangle) 40 20 placeSL
(trapezoid) 10 20 placeSL

showpage
