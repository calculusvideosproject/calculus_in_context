35 20 translate

sym
/k 0 def
5 {hashhor} repeat
/k 0 def
8 {hashver} repeat

0 0 moveto
330 0 arrowto
0 0 moveto
0 162 arrowto
fill

gsave				% begin thick lines
.9 recip mul setlinewidth
/s 45400 def
/i 2100 def
/splot s vscale mul def
/iplot i vscale mul def
/tplot 0 def
%tplot splot moveto
tplot iplot moveto
500 {curve} repeat
stroke

.6 recip mul setlinewidth
[2 1] 0 setdash
/t 0 def
/i 2100 def
0 2100 vscale mul moveto
polyeval5
stroke

/t 0 def
/i 2100 def
0 2100 vscale mul moveto
%polyeval10
stroke
/t 0 def
/i 2100 def
0 2100 vscale mul moveto
polyeval20
stroke

/t 0 def
/i 2100 def
0 2100 vscale mul moveto
polyeval30
stroke

/t 0 def
/i 2100 def
0 2100 vscale mul moveto
polyeval70
stroke

grestore			% end thick lines

ti (n = ) 40 110 placeBL
tr (20) show
2 2 rmoveto
115 100 arrowto
fill
ti (n = ) 30 80 placeBL
tr (5) show
2 1 rmoveto
85 74 arrowto
fill
ti (n = ) 166 120 placeBL
tr (70) show
163 121 moveto
123 105 arrowto
fill
ti (n = ) 160 40 placeBL
tr (30) show
157 43 moveto
125 46 arrowto
fill

TI (t) 330 1 placeTC
(I) -4 157 placeBR
(I = I) 300 57 placeBL
SYM (\() show
TI (x) show
SYM (\)) show

showpage

