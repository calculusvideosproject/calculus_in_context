% coord axes
newpath
0 0 moveto
350 0 rarrowto
0 0 moveto
0 115 rarrowto
fill

% ticks
/htick {0 -2 rlineto} def
/vtick {-2 0 rlineto} def
/hscale {currentpoint
pop 60 add 0 moveto 
htick} def
/vscale {currentpoint 
20 add 0 exch moveto		% 20 points = 25 sunspots
vtick} def

newpath
0 0 moveto
htick
5 {hscale} repeat
0 0 moveto
5 {vscale} repeat
stroke

% labels
sym 
(1820) 0 -1 placeTC
(1840) 60 -1 placeTC
(1860) 120 -1 placeTC
(1880) 180 -1 placeTC
(1900) 240 -1 placeTC
(1920) 300 -1 placeTC
(25) -5 18 placeBR
(50) -5 38 placeBR
(75) -5 58 placeBR
(100) -5 78 placeBR
(125) -5 98 placeBR
TR (year) 350 -1 placeTC
(Daily average number of sunspots) 170 -20 placeTC
gsave
90 rotate
(sunspots) 60 26 placeBC
grestore
showpage
