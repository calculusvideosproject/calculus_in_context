%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

-25 0 translate

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% ------------- defining units -----------------


%20 points = 1 graphical unit = 1 radian
/pi 3.14 def
/rad {20 div} def 			% pt --> rad
/pt  {15 mul} def 			% rad --> pt
/deg {180 mul pi div} def 		% rad --> deg

/dot {currentpoint 1 0 360 arc} def	% make a dot

/Sin {rad deg sin} def			% sin of angle 
/Cos {rad deg cos} def 			% cos of angle
/period {pi 2 mul pt} def


% ------------------- program -------------------------

.3 setlinewidth

% position the origin
%100 300 moveto				% screen origin
5 0 moveto
currentpoint translate

% ------------------ ticks -----------------

% ticks
/htick {0 -2 rlineto} def
/hscale {currentpoint
pop pi pt add 1 sub 0 moveto 
dot} def


% -------------------- first set of graphs  ---------------------

% define sinetest(k) = Sin(9k)
% define f(z) = az(1-z)  a = 3.95
% define plot(z) = 10(z - .5) = x
% define signal(k) = Sin(5k)

/f {dup neg 1 add mul 3.95 mul} def
/plot {.5 sub 10 mul} def
/signal {5 mul Sin} def
/sinetest{5 mul Sin} def

/total {
f
dup
4 1 roll
plot
exch
signal pt
add} def


% graph signal

gsave
.9 recip mul setlinewidth
newpath
0 0 signal pt moveto			% set initial point
.54					% initial z
1 1 150 				% sets k
{dup 
3 -1 roll 
total 
lineto
} for
stroke
grestore

% coord axes
newpath
0 0 moveto
155 0 rarrowto
0 -25 moveto
0 31 arrowto
fill

% amplitude marks

gsave
newpath					% save solid lines
[1 1] 0 setdash
162 0 pt moveto
18 0 rlineto
162 20 moveto
18 0 rlineto
stroke
grestore
newpath				% restore solid lines
171 -12 moveto
0 12 rarrowto
171 32 moveto
0 -12 rarrowto
fill

TR (original) 375  5 placeBL
(signal) 375 -5 placeBL
TI (t) 155 0 placeTC
(S) -4 31 placeBR
TR (frequencies match) 75 40 placeBC
TI (A) 171 6 placeBC

% graph of test function -------------------------

0 -60 moveto
currentpoint translate

gsave
.9 recip mul setlinewidth
newpath
0 0 moveto				% set initial point
1 1  150 				% sets k
{dup
sinetest pt
lineto} for
stroke
grestore

% coord axes
newpath
0 0 moveto
155 0 rarrowto
0 -18 moveto
0 40 rarrowto
fill

TR (test) 375 5 placeBL
(probe) 375 -5 placeBL
TI (t) 155 0 placeTC
(P) -4 22 placeBR

% graph of product --------------------------

0 -60 moveto
currentpoint translate

gsave
.9 recip mul setlinewidth
newpath
0 0 signal pt moveto			% set initial point
.54					% initial z
1 1 150 				% sets k
{dup dup
4 -1 roll 
f dup 5 1 roll 
plot exch signal pt add
exch sinetest
mul  
lineto} for
stroke

% average value
gsave
newpath
[2 1] 0 setdash
0 .5 pt moveto
150 0 rlineto
stroke
grestore
grestore

% coord axes
newpath
0 0 moveto
155 0 rarrowto
0 -20 moveto
0 45 rarrowto
fill

TR (their) 375 5 placeBL
(product) 375 -5 placeBL
TI (t) 155 0 placeTC
(S\264P) -4 25 placeBR
TI (S\264P) 153 9 placeBL
SYM ( \273 ) show
TI (A) show
SYM (/2) show
TR (average value) 40 -25 placeTL
SYM ( \273 ) show
TI (A) show
SYM (/2) show

% ---------------------- second set of graphs ---------------------------

205 120 moveto
currentpoint translate


% redefine sinetest(k) = Sin(7k)

/sinetest{7 mul Sin} def

% graph signal

gsave
.9 recip mul setlinewidth
newpath
0 0 signal pt moveto			% set initial point
.54					% initial z
1 1 150 				% sets k
{dup 
3 -1 roll 
total 
lineto
} for
stroke
grestore


% coord axes
newpath
0 0 moveto
155 0 rarrowto
0 -25 moveto
0 31 arrowto
fill


TI (t) 155 0 placeTC
(S) -4 31 placeBR
TR (frequencies do not match) 75 40 placeBC

% graph of test function -------------------------------

0 -60 moveto
currentpoint translate

gsave
.9 recip mul setlinewidth
newpath
0 0 moveto				% set initial point
.5 .5  150 				% sets k
{dup
sinetest pt
lineto} for
stroke
grestore

% coord axes
newpath
0 0 moveto
155 0 rarrowto
0 -18 moveto
0 40 rarrowto
fill

TI (t) 155 0 placeTC
(P) -4 22 placeBR

% graph of product -----------------------------

0 -60 moveto
currentpoint translate

gsave
.9 recip mul setlinewidth
newpath
0 0 signal pt moveto			% set initial point
.54					% initial z
1 1 150 				% sets k
{dup dup
4 -1 roll 
f dup 5 1 roll 
plot exch signal pt add
exch sinetest
mul  
lineto} for
stroke
grestore


% coord axes
newpath
0 0 moveto
155 0 rarrowto
0 -20 moveto
0 45 rarrowto
fill

TI (t) 155 0 placeTC
(S\264P) -4 25 placeBR
TR (average value) 40 -25 placeTL
SYM ( \273 0) show

showpage
