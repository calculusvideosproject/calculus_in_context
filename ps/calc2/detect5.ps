%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

40 0 translate

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% ------------- defining units -----------------


%100 points = 1 graphical unit = 1 radian
/pi 3.14159 def
/rad {100 div} def 			% pt --> rad
/pt  {100 mul} def 			% rad --> pt
/deg {180 mul pi div} def 	% rad --> deg

/dot {currentpoint .2 0 360 arc} def	% make a dot

/Sin {rad deg sin pt} def	% sin of angle given in pt
/Cos {rad deg cos pt} def	% cos of angle given in pt


% ------------------- program -------------------------

.3 setlinewidth

% position the origin
%100 500 moveto					% screen origin
20 0 moveto					% print origin
currentpoint translate

% ------------ differential equation solvers -------------------


/so 0 def
/eo 3 def
/osteps 2 8 exp cvi def
/do eo so sub osteps div def
/a 0 def
/b 10 def
/n 2 7 exp cvi def
/dt b a sub n div def
/o so def
/oldo o def
/oldaccum 0 def

% definition of probes
  /sinep {t  o mul pi mul 2 mul deg sin} def
/cosinep {t  o mul pi mul 2 mul deg cos} def

% definition of signal 
%/signal {t 5 mul deg sin 3 mul t 8 mul deg sin add} def
/signal {t 7 mul deg cos} def

/sineintegral
{/ds signal sinep mul dt mul b a sub div  def
/accum accum ds add def
/t t dt add  def
} def

/oldo o def
/oldaccum 0 def

/cosineintegral
{/ds signal cosinep mul dt mul b a sub div  def
/accum accum ds add def
/t t dt add  def
} def


/sineplot
{/t dt 2 div a add def
/accum 0 def
n {sineintegral} repeat
/o o do add def
oldo pt  oldaccum pt moveto
o pt  accum pt lineto
stroke
/oldo o def
/oldaccum accum def
} def 


/cosineplot
{/t dt 2 div a add def
/accum 0 def
n {cosineintegral} repeat
/o o do add def
oldo pt  oldaccum pt moveto
o pt  accum pt lineto
stroke
/oldo o def
/oldaccum accum def
} def 

/htick {0 -2 rlineto} def
/hscale {currentpoint
pop 100 pi div 2 div 2 rmoveto 
htick} def


% ------------------- plotting the graphs -----------------------

% ------------------- first graph --------------------

gsave
.9 recip mul setlinewidth
 osteps {sineplot} repeat
grestore

% coord axes

newpath
0 -40 moveto
300 0 rarrowto
0 -40 moveto
0 62 arrowto
fill

%ticks
0 0 moveto
-2 0 rlineto
0 50 moveto
-2 0 rlineto
0 -42 moveto
18 {hscale} repeat
stroke


% labels
SYM (w) 300 -36 placeBC
(5/2p) 500 2 div pi div -44 placeTC
(10/2p) 1000 2 div pi div -44 placeTC
(15/2p) 1500 2 div pi div -44 placeTC
(0) -5 0 placeBR
(1) -5 48 placeBR
TI (y) -5 60 placeBR
TR (cycles/sec) 290 -41 placeTL
(sine) -30 8 placeBR
(detector) -30 -2 placeBR
TI (y) 130 30 placeBL
SYM ( = ) show
TI (D) show
0 -2 rmoveto
(s) show
0 2 rmoveto
SYM (\(w\)) show



% ------------------- second graph --------------------

0 -130 moveto
currentpoint translate

/o so def
/oldo o def
/oldaccum 0 def

gsave
.9 recip mul setlinewidth
 osteps {cosineplot} repeat
grestore

% coord axes

newpath
0 -20 moveto
300 0 rarrowto
0 -20 moveto
0 70 arrowto
fill

%ticks
0 0 moveto
-2 0 rlineto
0 50 moveto
-2 0 rlineto
0 -22 moveto
18 {hscale} repeat
stroke


% labels
SYM (w) 300 -16 placeBC
(5/2p) 500 2 div pi div -24 placeTC
(10/2p) 1000 2 div pi div -24 placeTC
(15/2p) 1500 2 div pi div -24 placeTC
(0) -5 0 placeBR
(1) -5 48 placeBR
TI (y) -5 70 placeBR
TR (cycles/sec) 290 -21 placeTL
(cosine) -30 20 placeBR
(detector) -30 10 placeBR
TI (y) 128 41 placeBL
SYM ( = ) show
TI (D) show
0 -2 rmoveto
(c) show
0 2 rmoveto
SYM (\(w\)) show

showpage


