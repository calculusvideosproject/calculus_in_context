%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% -------------------------- program ----------------------------

 
/Sc   %scales points
{vscale mul exch hscale mul exch
} def
 
 /model1
 {/rp .1 r mul 1 r 10000 div sub mul .005 r f mul mul sub def
 /fp .00004 r f mul mul .04 f mul sub def
 /r r rp step mul add def
 /f f fp step mul add def
 r f Sc lineto
 } def
 
 /backmodel1
 {/rp .1 r mul 1 r 10000 div sub mul .005 r f mul mul sub def
 /fp .00004 r f mul mul .04 f mul sub def
 /r r rp step mul sub def
 /f f fp step mul sub def
 r f Sc lineto
 } def

 
/manyrun1
{/r k def
/f .1 k mul def
r f Sc moveto
{r rmax le {model1}{exit} ifelse} loop
stroke
/slope fp rp div def
/rs .95 r mul def
/fs f .05 r mul slope mul sub def
rs fs Sc moveto r f Sc arrowto fill
newpath
/r k def
/f .1 k mul def
r f Sc moveto
2500 {backmodel1} repeat
%%{f fmax le {backmodel}{exit} ifelse} loop
stroke
/k k 1 add def
} def

 /totalsteps 2500 def
 /size 100 def
 /step .01 def
.4 setlinewidth

10 0 translate
 
5 15 translate      %%%%Start of Picture 1
/rmax 10 def
 /fmax 1 def
 /tmax 250 def
 /hscale size rmax div def
 /vscale size .618 mul fmax div def
 
gsave
 newpath
 -15 -15 moveto
 rmax 1.3 mul 0 Sc rlineto
 0 fmax 1.3 mul Sc rlineto
 -15 fmax 1.3 mul Sc lineto
 closepath
 clip

 newpath
 /k 1 def
 gsave
  .8 recip mul setlinewidth
  10 {manyrun1} repeat
  0 fmax 1.1 mul Sc moveto 0 2.5 lineto
  3 0 moveto rmax 0 Sc lineto 
  stroke
  0 fmax 1.1 mul Sc moveto 0 2.5 arrowto fill
  3 0 moveto rmax 0 Sc arrowto fill
  0 0 1.25 recip mul 0 360 arc fill
 grestore
grestore

TI (O) -3 2 placeTR

 
         %%%%%%%%%%%%  Start of Picture 2

newpath
129 0 translate
50 0 1.25 recip mul 0 360 arc fill
TI (P) 50 0 placeTC
.8 recip mul setlinewidth
0 0 moveto 
48 0 lineto 
100 0 moveto 
52 0 arrowto 
stroke
0 0 moveto 48 0 arrowto fill
100 0 moveto 52 0 arrowto fill

% --------------------- Mathematica portion -------------------------

gsave
size size scale

% ----------------- Marrow drawing procedures ------------------

/Marrow 
{-4 size div 	0 		rmoveto
 0  		1 size div 	rlineto
 4 size div 	-1 size div 	rlineto
-4 size div 	-1 size div 	rlineto
 0  		1 size div 	rlineto
 4 size div 	0 		rlineto
} def

/Mrarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto Marrow neg rotate	% make Marrow
} def
/Marrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch Mrarrowto
} def

newpath
