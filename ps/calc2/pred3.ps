%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale .8 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

% 100 300 translate 		% print translation

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% -------------------- Ken's arrow drawing procedure --------------

/arrow
 {/mtrx matrix def
   /headlength exch def
   /halfheadthickness exch 2 div def
   /halfthickness exch 2 div def
   /tipy exch def /tipx exch def
   /taily exch def /tailx exch def
   
   /dx tipx tailx sub def
   /dy tipy taily sub def
   /arrowlength dx dx mul dy dy mul add sqrt def
   dx 0 ne {/angle dy dx atan def}
   	{dy 0 ne {/angle 90 dy dy abs div mul def}{/angle 0 def} ifelse}
	 ifelse
   /base arrowlength headlength sub def
   
   /savematrix mtrx currentmatrix def
   
   tailx taily translate
   angle rotate
   0 halfthickness neg moveto
   base halfthickness neg lineto
   base halfheadthickness neg lineto
   arrowlength 0 lineto
   base halfheadthickness lineto
   base halfthickness lineto
   0 halfthickness lineto
   closepath
   
   savematrix setmatrix
 }  def
 
% -------------------------- program ----------------------------

.3 setlinewidth

 /Sc   %scales points
 {vscale mul exch hscale mul exch} def
 
 /Schead
 {/dx rtip r sub hscale mul def
 /dy ftip f sub vscale mul def
 /s dx dx mul dy dy mul add sqrt .2 mul def
 s 2 le {}{/s 2 def} ifelse
 s mul exch s mul exch} def
  
/drawsub1
{/rp .1 r mul 1 r 10000 div sub mul .005 r f mul mul sub def
 /fp .00004 r f mul mul .04 f mul sub def
 /rtip r rp tchange mul add def
 /ftip f fp tchange mul add def
 r f Sc .75 0 360 arc fill
 r f Sc rtip ftip Sc .1 1 2 Schead arrow fill
 /r r 500 add def
 /f f 1 sub def 
 } def
 
 /sketch1
 {/f exch def
 /r exch def
 17 {drawsub1} repeat
 } def 

/drawsub2
{/rp .1 r mul 1 r 10000 div sub mul .005 r f mul mul sub def
 /fp .00004 r f mul mul .04 f mul sub def
 /rtip r rp tchange mul add def
 /ftip f fp tchange mul add def
 r f Sc .75 0 360 arc fill
 r f Sc rtip ftip Sc .1 1 2 Schead arrow fill
 /f f 2 add def 
 } def
 
 /sketch2
 {/f exch def
 /r exch def
 16 {drawsub2} repeat
 } def 

 /model
 {/rp .1 r mul 1 r 10000 div sub mul .005 r f mul mul sub def
 /fp .00004 r f mul mul .04 f mul sub def
 /r r rp step mul add def
 /f f fp step mul add def
 /t t step add def
 r f Sc lineto
 } def
 
/horgrid
{/number exch def
/change fmax number idiv def
/k 0 def
number {hashver} repeat
} def

/vergrid
{/number exch def
/change rmax number idiv def
/k 0 def
number {hashhor} repeat
} def


/hashver
{/k k change add def
/posit k vscale mul def
k (            ) cvs dup stringwidth pop 7 add neg 
2 add posit 2 sub moveto
show
-2 posit moveto 
0 posit lineto stroke
} def

/hashhor
{/k k change add def
/posit k hscale mul def
k (     ) cvs dup stringwidth pop 2 div
posit exch sub -11 moveto
show
posit -2 moveto
posit 0 lineto stroke
} def

/fpline
{/f 20 .002 r mul sub def} def
 
 /totalsteps 2500 def
 /hscale .03 def
 /vscale 6 def
 /tscale 1.2 def
 /rmax 12000 def
 /fmax 30 def
 /tmax 250 def
 /tchange 2 def
 /fchange 2 def
 /rchange 500 def
 /step tmax totalsteps div def
 
 
 
80 40 translate


rmax hscale mul 15 add 0 10000 hscale mul 3 add 0 .5 3 6 arrow fill
0 fmax vscale mul 15 add 0 3 .5 3 6 arrow fill
4 0 10000 hscale mul 3 sub 0 .5 3 6 arrow fill
10000 0 Sc 2 0 360 arc fill
0 0 2 0 360 arc fill
/r 1000 def
r fpline
r f Sc 2 0 360 arc fill
TI (R) rmax hscale mul 25 add 1 placeTC
(F) -5 fmax vscale mul 16 add placeBR
TI (O) -12 -12 placeBL
(P) 10000 .8 Sc placeBL
(Q) r 150 add f .5 add Sc placeBL
sym
6 horgrid
6 vergrid

 
gsave
  .5 recip mul setlinewidth
  [1 2] 0 setdash
  1000 hscale mul 0 moveto
  1000 hscale mul fmax 3 add vscale mul lineto stroke
  /r 10000 def
  r fpline
  0 20 vscale mul moveto
  r f Sc lineto stroke 
grestore
gsave
  1000 hscale mul 4 vscale mul translate
  90 rotate
  TI (F) 0 3 placeBL
  1 0 rmoveto
  SYM (\242 = 0) show
grestore
gsave
  2200 hscale mul 15 vscale mul translate
  /th -22 def
  th rotate
  TI (R) 0 -9 placeBL
  1 0 rmoveto
  SYM (\242 = 0) show
grestore

newpath
/a 3300 hscale mul def
/b 25 vscale mul def
TR (I:) a b placeBR
TI (R) a 3 add b 6 add placeBL
1 0 rmoveto
SYM (\242 < 0) show
TI (F) a 3 add b 7 sub placeBL
1 0 rmoveto
SYM (\242 > 0) show
a b moveto
-13 -11 rmoveto
50 0 rlineto
0 30 rlineto
-50 0 rlineto
closepath
stroke

newpath
/a 2900 hscale mul def
/b 6 vscale mul def
TR (II:) a b placeBR
TI (R) a 3 add b 6 add placeBL
1 0 rmoveto
SYM (\242 > 0) show
TI (F) a 3 add b 7 sub placeBL
1 0 rmoveto
SYM (\242 > 0) show
a b moveto
-16 -11 rmoveto
54 0 rlineto
0 30 rlineto
-54 0 rlineto
closepath
stroke

newpath
/a -2000 hscale mul def
/b 9 vscale mul def
TR (III:) a b placeBR
TI (R) a 3 add b 6 add placeBL
1 0 rmoveto
SYM (\242 > 0) show
TI (F) a 3 add b 7 sub placeBL
1 0 rmoveto
SYM (\242 < 0) show
a b moveto
-20 -11 rmoveto
58 0 rlineto
0 30 rlineto
-58 0 rlineto
closepath
a b moveto
-20 -11 rmoveto
58 0 rmoveto
0 10 rmoveto
33 -10 rlineto
currentpoint 1 0 360 arc 
stroke

newpath
/a -2000 hscale mul def
/b 28 vscale mul def
TR (IV:) a b placeBR
TI (R) a 3 add b 6 add placeBL
1 0 rmoveto
SYM (\242 < 0) show
TI (F) a 3 add b 7 sub placeBL
1 0 rmoveto
SYM (\242 < 0) show
a b moveto
-20 -11 rmoveto
58 0 rlineto
0 30 rlineto
-58 0 rlineto
closepath
a b moveto
-20 -11 rmoveto
58 0 rmoveto
0 14 rmoveto
36 -14 rlineto
currentpoint 1 0 360 arc
stroke

newpath
1500 17 sketch1
/r 500 def
/f 19 def
drawsub1
1000 2.01 sketch2 
/r 2000 def
/f 10 def
drawsub1
/r 6000 def
/f 3 def
drawsub1
/r 2000 def
/f 22 def
drawsub1
/r 500 def
/f 23 def
drawsub1
/r 500 def
/f 12 def
drawsub1
/r 6000 def
/f 18 def
drawsub1
/r 3000 def
/f 2 def
drawsub1
/r 1400 def
/f 30 def
drawsub1
/r 10000 def
/f 16 def
drawsub1
/r 800 def
/f 29 def
drawsub1                            
			    
showpage
