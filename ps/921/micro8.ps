% Mathematica code
%
%  plot3 =
%  ContourPlot[
%  	2.75 (x - 1.5) + 2 (y + 1) - 3.625, {x, 1.4, 1.6}, {y, -1.1, -.9},
%  	Contours -> {-66/16, -65/16, -64/16, -63/16, -62/16,
%  		-61/16, -60/16, -59/16, -58/16, -57/16, -56/16, 
%  		-55/16, -54/16, -53/16, -52/16, -51/16, -50/16},
%  	ContourShading -> False,
%  	Ticks -> False,
%  	Frame -> None,
%  	PlotPoints -> 10
%  ]
%  

%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -300 
{ 0 exch moveto
  500 0 rlineto
} for
%stroke				% comment out here to eliminate grid lines
grestore

