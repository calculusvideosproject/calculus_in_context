% Mathematica code
%
%  Show[ v4plus, tang5 ]
%  
%  v4plus = 
%  Plot3D[ x^3 - 4 x - y^2, {x, -2.5, 2.5}, {y, -2.5, 2.5},
%  	AmbientLight -> GrayLevel[.2],
%  	SphericalRegion -> True,
%  	PlotPoints -> {36, 27},
%  	BoxRatios -> {1, 1, .9},
%  	ViewPoint->{-2.821, -8.457, 1.233},
%  	AxesEdge -> {Automatic, {-1,-1}, Automatic},
%  	FaceGrids -> {{0,0,-1}}
%  ]
%  
%  tang5 = 
%  Plot3D[2.75 x + 2 y + 7.5, {x, -2.3, -.7}, {y, -1.8, -.3},
%  	SphericalRegion -> True,
%  	ColorFunction -> (GrayLevel[1]&),
%  	PlotPoints -> {2, 2},
%  	PlotRange -> {-12, 6},
%  	BoxRatios -> {1, 1, .9},
%  	ViewPoint->{-2.821, -8.457, 1.233}
%  ]
%  

%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -300 
{ 0 exch moveto
  500 0 rlineto
} for
%  stroke			% comment out here to eliminate grid lines
grestore

