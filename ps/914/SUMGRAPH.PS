% Mathematica code
%
% Plot3D[e[x, y], {x, -1.5, 1.5}, {y, -1.5, 1.5},
%	AmbientLight -> GrayLevel[.2],
%	BoxRatios -> {1, 1, .8},
%	PlotPoints -> 40,
%	PlotRange -> {0, 35},
%	AxesEdge -> {Automatic, {-1, -1}, Automatic},
%	ViewPoint->{-1.552, -8.500, 1.613}
% ]
%

%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

% ------------------ graphics instructions --------------------

.3 setlinewidth

% position the origin
0 0 moveto				% screen origin
currentpoint translate

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	


/x 140 def
/y -162 def
/z -102 def

newpath
x y moveto
bigdot
x y moveto
22 -167 lineto
x y moveto
12 -14 rlineto
stroke

newpath
21 -167 moveto
smalldot
x 13 add y -15 add moveto
smalldot
x 70 add z -10 add moveto
smalldot
stroke

newpath
x z moveto
bigdot
x y moveto
0 35 rlineto
x z moveto
15 -13 rlineto
54 3 rlineto
-16 12 rlineto
stroke

gsave
newpath
[.3 1] 0 setdash
x z moveto
0 -25 rlineto
x z moveto
54 3 rlineto
stroke
grestore

% arrows to points
newpath
225 -155 moveto
-175 rotate
75 0 rlineto
arrow
175 rotate
225 -71 moveto
-160 rotate
83 0 rlineto
arrow
160 rotate
stroke

