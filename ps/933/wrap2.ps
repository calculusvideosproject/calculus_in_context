% Mathematica code
%
% Show[cylinderslit1, curveslit1,
% 	Boxed -> False,
% 	Axes -> False,
% 	BoxRatios -> {.8, .8, 1}
% ]
% cylinderslit1 = 
% ParametricPlot3D[
% 	{2 Cos[.1 Pi + .95 t], 2 Sin[.1 Pi + .95 t], z},
% 	{t, 0, 2 Pi}, {z, -50, 100},
% 	PlotPoints -> {21, 9},
% 	BoxRatios -> {1, 1,.9},
% 	ViewPoint->{3.897, -2.648, 0.918}
% ]
% curveslit1 = 
% ParametricPlot3D[
% 	{2 Cos[.1 Pi + .95 t], 2 Sin[.1 Pi + .95 t], 
% 	(2 Cos[t])^2 + 8 (2 Cos[t]) (2 Sin[t]) + 
% 	3 (2 Sin[t]) ^2 - 5 (2 Cos[t]) + 1}, 
% 	{t, 0 , 2 Pi},
% 	ViewPoint->{3.593, -3.168, 0.933}
% ]

%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	
/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -300 
{ 0 exch moveto
  500 0 rlineto
} for
% stroke			% comment out here to eliminate grid lines
grestore

%%EPS Trailer
