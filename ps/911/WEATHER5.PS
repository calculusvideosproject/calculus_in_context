% *** CODE ****
%
% W[d_, s_] := 55 - 5 Exp[-d/2] - 25 Exp[-d/2] Cos[2 Pi (s - 1 - 3 (1  - %Exp[-d/2]))/12 ]
%
% T[d, s] = W[s, d]
%
% Plot3D[T[s,d], {s, 0, 25}, {d, 0, 10}, 
%	AmbientLight -> GrayLevel[0.3],
%	PlotRange -> {20, 78}, PlotPoints -> {51, 21}, 
%	BoxRatios -> {-1, 1, .8}, ViewPoint->{2.868, 1.519, 0.957},
%	Ticks -> {
%		{3, 6, 9, 12, 15, 18, 21, 24}, 
%		{2, 4, 6, 8, 10},
%		{30, 40, 50, 60, 70}
%	}
% ]

%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

% ------------------ graphics instructions --------------------

.3 setlinewidth

% position the origin
0 0 moveto				% screen origin
% 20 -4 moveto
currentpoint translate

% ----------------- arrow drawing procedures ------------------

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def

gsave
newpath
174 -290 moveto
-3 136 rlineto
uparrow
stroke
grestore



