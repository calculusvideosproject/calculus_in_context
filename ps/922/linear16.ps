%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	

newpath
150 -202 moveto
142 rotate
28 0 rmoveto
arrow
-142 rotate
150 -105 moveto
119 rotate
44 0 rmoveto
arrow
-119 rotate
stroke

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -300 
{ 0 exch moveto
  500 0 rlineto
} for
% stroke				% comment out here to eliminate grid lines
grestore

gsave
[1 2] 0 setdash
150 -200 moveto
150 -168 lineto
127 -181 moveto
127 -162 lineto
stroke
grestore

