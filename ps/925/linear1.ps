% Mathematica code
%
% ContourPlot[ 3 x + 4 y + 12, {x, 0, 4}, {y, 0, 4},
%	Contours -> {12, 15, 18, 21, 24, 27, 30, 33, 36, 39},
%	ContourShading -> False
% ]
%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	
/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

gsave
newpath
15 -170 moveto
180 -10 lineto
190 -25 lineto
30 -180 lineto
closepath
1 setgray
fill
grestore

% -------------------- font codes --------------------------

/printscale 1 def
/typesize {10 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTRbig {/Times-Roman findfont 12 scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeTIbig {/Times-Italic findfont 12 scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/TR {makeTR setfont} def
/TRbig {makeTRbig setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/TIbig {makeTIbig setfont} def
/SYM {makeSYM setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% my labels
TI (x) 205 -200 placeBL
(y) 6 7 placeBR
SYM (15) 32 -170 placeBC
(18) 51 -150 placeBC
(21) 71 -130 placeBC
(24) 92 -111 placeBC
(27) 112 -92 placeBC
(30) 131 -72 placeBC
(33) 152 -54 placeBC
(36) 171 -34 placeBC
 
TRbig (contours of ) 55 -205 placeTL
TIbig (L) show
0 -3 rmoveto
TR (1) show
0 3 rmoveto
(\() show
TIbig (x, y) show
TRbig (\)) show

gsave
newpath
.4 setgray
0 50 500 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -300 
{ 0 exch moveto
  500 0 rlineto
} for
% stroke			% comment out here to eliminate grid lines
grestore

%%EPS Trailer
