% Mathematica code
%
% Show[ field, f1, f2, f3a, f4, f5, f6, f7, f8,
% 	Axes -> None,
% 	Frame -> True 
% ]
% field =
% PlotGradientField[ - x^4 + x^2 y^2 - y^4 -2 x^2 + 5 x y + y,
% 	{x, -2, 2}, {y, -2, 2}, 
% 	ScaleFunction -> (#/(#+1)&),
% 	ScaleFactor -> .15
% ]
% f1 = ParametricPlot[ Evaluate[ {x[t], y[t]} /. flow1],
% 	{t, 0, 10}, PlotRange -> All ] 
% flow1 =
% NDSolve[
% 	{x'[t] == 2 x[t] (y[t])^2  - 4 (x[t])^3 - 4 x[t] + 5 y[t],
% 	 y'[t] == 2 (x[t])^2 y[t] - 4 (y[t])^3 + 5 x[t] + 1,
% 	 x[0] == 1.9, y[0] == -.2},
% 	{x, y}, {t, 10}
% ]
% f2 = ParametricPlot[ Evaluate[ {x[t], y[t]} /. flow2],
% 	{t, 0, 10}, PlotRange -> All ] 
% flow2 =
% NDSolve[
% 	{x'[t] == 2 x[t] (y[t])^2  - 4 (x[t])^3 - 4 x[t] + 5 y[t],
% 	 y'[t] == 2 (x[t])^2 y[t] - 4 (y[t])^3 + 5 x[t] + 1,
% 	 x[0] == 1.9, y[0] == -1.4},
% 	{x, y}, {t, 10}
% ]
% f3a = ParametricPlot[ Evaluate[ {x[t], y[t]} /. flow3a],
% 	{t, 0, 10}, PlotRange -> All ] 
% flow3a =
% NDSolve[
% 	{x'[t] == 2 x[t] (y[t])^2  - 4 (x[t])^3 - 4 x[t] + 5 y[t],
% 	 y'[t] == 2 (x[t])^2 y[t] - 4 (y[t])^3 + 5 x[t] + 1,
