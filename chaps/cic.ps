% Mathematica code
%
% Show[graph4, Graphics[box3], Graphics[box4]]
% graph4 =
% Plot[ funny, {x, 26.98, 27.02}, 
% 	AspectRatio -> .8,
% 	PlotRange -> {69.82, 69.9},
% 	AxesOrigin -> {26.98, 69.82} 
% ]
% box3 =
% Line[{{26.98, 69.82}, {26.98, 69.9}, {27.02, 69.9}, {27.02, 69.82}, {26.98, 69.82}}]
% box4 =
% Line[{{26.998, 69.855}, {26.998, 69.863}, {27.002, 69.863}, {27.002, 69.855}, {26.998, 69.855}}]
% funny = (2 + x^3 Cos[x] + 1.5^x)/(2 + x^2)
% 
%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

