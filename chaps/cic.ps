fill

/smbox {			% stack: x y for center
  moveto
  -3 -3 rmoveto
  6 0 rlineto
  0 6 rlineto
  -6 0 rlineto
  closepath
} def
  
/bigbox {			% stack: x y for center
  moveto
  -35 -35 rmoveto
  70 0 rlineto
  0 70 rlineto
  -70 0 rlineto
  closepath
} def

