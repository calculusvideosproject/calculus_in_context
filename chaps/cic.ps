%%BeginDocument: ../ps/calc1/int1.ps
%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792
/printscale 1 def
/recip {1 printscale div} def
/screenstretch {printscale 90 50 div mul} def
/double {screenstretch 2 mul} def

%100 300 translate		% print translation

 printscale printscale scale       %scale for printing
% screenstretch screenstretch scale %printing scale on screen
% double double scale               %magnified screen

% -------------------- font codes --------------------------

/typesize {10 printscale div} def
/smalltype {8 printscale div} def

/makeTR {/Times-Roman findfont typesize scalefont} def
/makeTB {/Times-Bold findfont typesize scalefont} def
/makeTI {/Times-Italic findfont typesize scalefont} def
/makeSYM {/Symbol findfont typesize scalefont} def

/maketr {/Times-Roman findfont smalltype scalefont} def
/maketi {/Times-Italic findfont smalltype scalefont} def
/makesym {/Symbol findfont smalltype scalefont} def

/TR {makeTR setfont} def
/TB {makeTB setfont} def
/TI {makeTI setfont} def
/SYM {makeSYM setfont} def

/tr {maketr setfont} def
/ti {maketi setfont} def
/sym {makesym setfont} def

% ---------------string placing procedures-------------------

% stack: fontcode string x y 

/placeBL {moveto show} def
/placeBR {moveto dup stringwidth pop neg 0 rmoveto show} def
/placeBC {moveto dup stringwidth pop 2 div neg 0 rmoveto show} def
/placeTL {moveto 0 typesize neg rmoveto show} def
/placeTR {moveto dup stringwidth pop neg typesize neg rmoveto show} def
/placeTC {moveto dup stringwidth pop 2 div neg typesize neg rmoveto show} def

% ----------------- arrow drawing procedures ------------------

/arrow 
{-4 recip mul 	0 		rmoveto
 0  		1 recip mul 	rlineto
 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

% ------------------- program -------------------------

.3 setlinewidth

% position the origin
%50 80 moveto				% screen origin
25 0 moveto
currentpoint translate


% definition of function y = f(x) = 5u(10u/2^u + .5), 
% u = x/10

/f				% input x
{10 div			% make u = x/10
dup dup
2 exch
exp
div
10 mul
.5 add
mul
5 mul
10 sub
} def


gsave				% make clip for hatching
/initial 10 def
/step 5 def

initial initial f moveto
initial step add step 110	% gives x value
{dup f 				% gives x, y point
 lineto				% draws line from previous point
} for
110 0 lineto
10 0 lineto
10 10 f lineto
clip
.1 setlinewidth
-100 4 110
{0 moveto
100 100 rlineto
} for
stroke
grestore				% finish hatching

% draw the graph of f

gsave
.9 recip mul setlinewidth
/initial 8 def
/step 5 def

initial initial f moveto
initial step add step 120	% gives x value
{dup f 				% gives x, y point
 lineto				% draws line from previous point
} for
stroke				% draw the graph
grestore

% definition of g(x) = 25 + x(120 - x)/60

/g
{ dup
120 sub
neg
mul
60 div
22 add
} def

gsave				% make clip for hatching

/initial 10 def
/step 5 def

initial initial g moveto
initial step add step 110	% gives x value
{dup g 				% gives x, y point
 lineto				% draws line from previous point
} for
110 0 lineto
10 0 lineto
10 10 g lineto
clip
.1 setlinewidth
0 4 220
{0 moveto
-100 100 rlineto
} for
stroke
grestore				% finish hatching




% draw the graph of g

gsave
.9 recip mul setlinewidth
/initial 8 def
/step 5 def

initial initial g moveto
initial step add step 113	% gives x value
{dup g 				% gives x, y point
 lineto				% draws line from previous point
} for
stroke				% draw the graph
grestore

110 110 g moveto
110 0 lineto
10 0 lineto
10 10 g lineto
stroke				% draw the graph

% coord axes
newpath
-15 0 moveto
150 0 rarrowto
0 -10 moveto
0 103 rarrowto
fill

% labels
TI (a) 10 0 placeTC
(b) 110 0 placeTC
(x) 135 1 placeTC
(y) -3 90 placeBR
(y = g) 85 85 g 8 add placeBL
1 0 rmoveto TR (\() show
TI (x) show
TR (\)) show
TI(y = f) 122 120 f 4 sub placeBL
2 0 rmoveto TR (\() show
TI (x) show
TR (\)) show


% -------------------- second graph -----------------------

% reposition the origin
210 0 moveto				% screen origin
%250 0 moveto
currentpoint translate

gsave				% shading for area
/initial 10 def
/step 5 def

initial initial f moveto
initial step add step 110	% gives x value
{dup f 				% gives x, y point
 lineto				% draws line from previous point
} for
110 0 lineto
10 0 lineto
10 10 f lineto
.9 setgray
fill
grestore				% finish shading

% draw the graph of f

gsave
.9 recip mul setlinewidth
/initial 8 def
/step 5 def

initial initial f moveto
initial step add step 120	% gives x value
{dup f 				% gives x, y point
 lineto				% draws line from previous point
} for
stroke				% draw the graph
grestore

% coord axes
newpath
-15 -.1 moveto
150 0 rarrowto
0 -10 moveto
0 78 rarrowto
fill

% vertical lines
10 -2 moveto
10 10 f lineto
110 -2 moveto
110 110 f lineto
50 -2 moveto
50 50 f lineto
stroke


% labels
TI (a) 10 0 placeTC
(c) 50 0 placeTC
(b) 110 0 placeTC
(x) 135 1 placeTC
(y) -3 65 placeBR
(y = f) 65 65 f 8 add placeBL
2 0 rmoveto TR (\() show
TI (x) show
TR (\)) show


showpage




%%EndDocument
 @endspecial eop end
