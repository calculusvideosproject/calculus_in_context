 4 recip mul 	-1 recip mul 	rlineto
-4 recip mul 	-1 recip mul 	rlineto
 0  		1 recip mul 	rlineto
 4 recip mul 	0 		rlineto} def

/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def


% ------------------- program -------------------------

.3 printscale div setlinewidth

% position the origin
6 40 moveto				% screen origin
currentpoint translate


% definition of function y = f(x)

/f				% input x
{ 125 sub			% form x-125
dup dup			% save two copies of x-125 on stack
dup mul			% make (x-125)^2
-.000002 mul		% make -.000002(x-125)^2 = -A
.02 add 			% make .02 -A = B
mul				% make (x-125)B
.15 add			% .15+ (x-125)B
mul				% make (x-125)[.15 + (x-125)B]
-18 add			% add -18 
1.2 mul			% multiply by 1.2 to complete formula
} def

% shaded region

gsave					% save black lines
/initial 51 def
newpath
initial dup f moveto		% initial point

/step 6  def

initial step add step 183 	% gives x value
{dup f 				% gives x, y point
 2 copy				% makes a second copy for stack
 lineto				% draws line from previous point
} for
183 0 lineto
51 0 lineto
51 51 f lineto
.9 setgray
fill 
grestore					% restore black lines


% graph of f

gsave
/initial 33 def
newpath
.9 recip mul setlinewidth
initial dup f moveto			% initial point
/step 3  def
initial step add step 210	% gives x value
{dup f 				% gives x, y point
 2 copy				% makes a second copy for stack
 lineto				% draws line from previous point
} for
stroke				% draw the graph
grestore

% coord axes
newpath
0 0 moveto
230 0 rarrowto
10 -32 moveto
0 88 rarrowto
fill

% lines to regions

/dot {.8 0 360 arc} def	% make a dot

newpath
100 37 moveto
64 14 lineto
140 37 moveto
173 17 lineto
148 -21 moveto
125 -12 lineto
stroke


64 14 dot
fill
173 17 dot
fill
125 -12 dot
fill

TI (a) 51 1 placeTC
(b) 183 1 placeTC
(x) 230 1 placeTC
(y) 7 55 placeBR
(y = f) 203 44 placeTL
1 0 rmoveto TR (\() show
TI (x) show
TR (\)) show
TR (upper region) 120 35 placeBC
(lower region) 150 -24 placeBL

showpage



