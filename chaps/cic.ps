% Mathematica code
%
% Show[graph1, Graphics[box1]]
% graph1 =
% Plot[ funny, {x, -20, 35}, 
% 	PlotRange -> {-40, 105},
% 	AspectRatio -> 1 ]
% box1 =
% Line[{{25, 66}, {25, 76}, {28, 76}, {28, 66}, {25, 66}}]
% funny = (2 + x^3 Cos[x] + 1.5^x)/(2 + x^2)
%
% the following scale is needed to convert back to my coordinate system;
% no other scaling changes are needed.

1 -1 scale

/arrow 
{-2 0 rmoveto
 0  1 rlineto
 4 -1 rlineto
-4 -1 rlineto
 0  1 rlineto
 2 0 rlineto} def

/rightarrow {arrow} def
/uparrow {90 rotate arrow -90 rotate} def
/leftarrow {180 rotate arrow -180 rotate} def
/downarrow {-90 rotate arrow 90 rotate} def
/bigdot {currentpoint 1.5 0 360 arc fill} def	
/smalldot {currentpoint 1 0 360 arc fill} def	
/rarrowto {					% stack: dx dy
  2 copy
  dup mul exch dup mul add  sqrt		% length of arrow
  3 1 roll exch atan dup 				% angle
  rotate exch 0 rlineto arrow neg rotate	% make arrow
} def
/arrowto {					% stack: x y
  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def

gsave
[.6 3] 0 setdash
180 -42 moveto		% 1 to 2
250 -10 lineto
180 -60 moveto
260 -195 lineto
358 -115 moveto		% 2 to 3
480 -16 lineto
360 -135 moveto
477 -179 lineto
559 -115 moveto		% 3 to 4
488 -233 lineto
578 -115 moveto
647 -233 lineto
575 -300 moveto		% 4 to 5
442 -257 lineto
575 -315 moveto
442 -397 lineto
357 -318 moveto		% 5  to 6
208 -261 lineto
357 -335 moveto
208 -409 lineto
stroke
grestore

gsave
newpath
.4 setgray
0 50 600 
{ 0 moveto
  0 -400 rlineto
} for
0 -50 -400 
{ 0 exch moveto
  600 0 rlineto
} for
% stroke			% comment out here to eliminate grid lines
grestore

