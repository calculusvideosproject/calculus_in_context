/b b .015 b 1.2 exp mul delta mul add def
/y b log 15 mul def
x y lineto
} def

/curve2
{/a a 1 add def
/x a 288 mul 240 div def 
/b  -5 c .003 a mul sub log mul def
/y b 15 mul def
x y lineto} def

/hscale
{/Times-Roman findfont
12 scalefont setfont
