%%BeginDocument: ../ps/calc1/shaded.ps
%!PS-Adobe-2.0 EPSF-2.0
%%BoundingBox: 0 0 612.0 792

% 100 400 translate 			% print translation

/Hscale 1 def
/Vscale 1 def

/Times-Roman findfont
/fac 10 def
fac scalefont setfont

/Mdot {
gsave
1 Hscale div 1 Vscale div scale
Vscale mul
exch
Hscale mul
exch
1.5 0 360 arc
fill
grestore} def
% General format for Mshowa is
%[(text)] xcoord ycoord a b Mshowa
% where a=1 (-1) means position at right (left) of point
%and y=1 (-1) means above (below) point.
%Final show position is 
%xcoord +.5(a-1)w +.3 a fac,
%ycoord + (.65 b -.35) fac
%w = width of text, fac = fontsize
%Changing b only affects vertical placement--unit change in b gives not quite a fontsize height change
%changing a only affects horizontal--unit change in a give .5 textwidth plus slightly less than half a fontheight
% the parameter .3 gives horizontal distance from point
% change the -.35 to alter vertical closeness
/Mshowa {
gsave
1 Hscale div 1 Vscale div scale   %first seven lines convert to absolute scale
4 2 roll
Vscale mul
exch
Hscale mul
exch
4 2 roll
.65 mul
exch dup .3 mul fac mul
exch 1 sub .5 mul
6 -1 roll
0 get
dup stringwidth pop
exch
7 1 roll
mul add
4 -1 roll
add
3 1 roll
.35 sub fac mul add
moveto
show
grestore
} def

/arrowdict 14 dict def
arrowdict begin
 /mtrx matrix def
end
/arrow
 {arrowdict begin
   /headlength exch def
   /halfheadthickness exch 2 div def
   /halfthickness exch 2 div def
   /tipy exch def /tipx exch def
   /taily exch def /tailx exch def
   
   /dx tipx tailx sub def
   /dy tipy taily sub def
   /arrowlength dx dx mul dy dy mul add sqrt def
   /angle dy dx atan def
   /base arrowlength headlength sub def
   
   /savematrix mtrx currentmatrix def
   
   tailx taily translate
   angle rotate
   0 halfthickness neg moveto
   base halfthickness neg lineto
   base halfheadthickness neg lineto
   arrowlength 0 lineto
   base halfheadthickness lineto
   base halfthickness lineto
   0 halfthickness lineto
   closepath
   
   savematrix setmatrix
   end
 }  def

