  currentpoint 3 -1 roll sub neg 3 1 roll sub exch rarrowto
} def



% ------------------------ program ------------------------------

.3 recip mul setlinewidth

% -------------------------- trapezoid ---------------------------------

% set the origin
 40 0 moveto
% 0 180 moveto
currentpoint translate

gsave		% start clipped region for shading

newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
clip


grestore	% end clipped region for shading

% trapezoid with graph

gsave				% begin medium lines
.5 recip mul setlinewidth
newpath
75 0 moveto
75 113.7 lineto
90 126.4 lineto
90 0 lineto
closepath
stroke

% rectangles - dotted lines

gsave
[1 1] 0 setdash
newpath
90 113.7 moveto
75 113.7 lineto
75 126.4 lineto
90 126.4 lineto
stroke
grestore
grestore			% end medium lines


gsave  % start clipped region for graph

newpath
-10 0 moveto 
0 150 rlineto
150 0 rlineto
0 -150 rlineto
-150 0 rlineto
clip

gsave				% begin thick lines
.9 recip mul setlinewidth
newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke
grestore			% end thick lines

grestore % end clipped region for graph

% coordinate axes
newpath
-40 0 moveto
190 0 rarrowto
-20 -10 moveto
0 130 rarrowto
fill

% central rectangle/trapezoid
newpath
0 0 moveto
0 2 rlineto
125 0 moveto
0 2 rlineto
stroke

75.1 -10 moveto
0 9 rarrowto
90.1 -10 moveto
0 9 rarrowto
fill

 
% labels on axes and graph
newpath
TI (a) 0 0 placeTC
(b) 126 0 placeTC 
(x) 150 0 placeTC
(y) -23 118 placeBR
(y = f) -5 47 placeBL
1 0 rmoveto TR (\() show
TI (x) show
TR (\)) show
(left) 75 -9 placeTR
(endpoint) 75 -16 placeTR
(right) 90 -9 placeTL
(endpoint) 90 -16 placeTL

% big arrow

newpath
118 40 moveto
20 0 rlineto
0 -5 rlineto
20 20 rlineto
-20 20 rlineto
0 -5 rlineto
-20 0 rlineto
closepath
stroke

% --------------------  two rectangles and one trapezoid ------------------

105 0 moveto
currentpoint translate

.5 recip mul setlinewidth	% begin medium lines

gsave
[1 1] 0 setdash
newpath
75 0 moveto
75 113.7 lineto
90 113.7 lineto
90 0 lineto
closepath
stroke

60 0 moveto
currentpoint translate
newpath
75 0 moveto
75 126.4 lineto
90 126.4 lineto
90 0 lineto
closepath
stroke

grestore

30 0 moveto
currentpoint translate

newpath
75 0 moveto
75 113.7 lineto
90 126.4 lineto
90 0 lineto
closepath
stroke

75 0 moveto
currentpoint translate

