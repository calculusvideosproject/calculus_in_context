0 -123 rlineto
0 0 lineto
stroke
grestore

gsave  % start clipped region for graph

newpath
-10 0 moveto 
0 150 rlineto
150 0 rlineto
0 -150 rlineto
-150 0 rlineto
clip

gsave				% begin thick lines
.9 recip mul setlinewidth
newpath
20 40 moveto
80 30 45 160 125 120 curveto
225 70 150 -50 70 -50 curveto
0 -50 -60 55 20 40 curveto
stroke
grestore			% end thick lines

grestore % end clipped region for graph

% labels on axes and graph
newpath
TI (a) 0 0 placeTC
(b) 125 0 placeTC 
(x) 150 0 placeTC
(y) -23 118 placeBR
(y = f) 20 90 placeBL
1 0 rmoveto TR (\() show
TI (x) show
TR (\)) show
(rectangular) 60 -12 placeTC
(approximation) 60 -25 placeTC

